// ============================================================
// FIREBASE STORAGE SECURITY RULES — StudentMS
// Deploy via: firebase deploy --only storage
// ============================================================

rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // ── Student photos ────────────────────────────────────
    // Path: students/{docId}/{filename}.jpg
    match /students/{docId}/{fileName} {

      // Any authenticated user can read
      allow read: if request.auth != null;

      // Any authenticated user can upload images (max 10MB, image types only)
      allow write: if request.auth != null
        && request.resource.size <= 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');

      // Any authenticated user can delete (admins handle via service)
      allow delete: if request.auth != null;
    }

    // ── Deny all other paths ──────────────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
